---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-divider)] bg-[var(--color-bg-primary)]">
  <div class="container-tailor py-16 pb-safe">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4 group" aria-label="Tailor App Studio — home">
          <Logo size={40} />
          <span class="text-lg font-bold tracking-tight group-hover:text-[var(--color-accent-bright)] transition-colors">Tailor App Studio</span>
        </a>
        <p class="text-[var(--color-text-secondary)] max-w-[36ch] leading-relaxed">
          Applicazioni cucite su misura per il tuo business.
        </p>
      </div>

      <nav aria-label="Sezioni" class="space-y-3">
        <h3 class="text-sm uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-4">Sezioni</h3>
        <ul class="space-y-2 text-[var(--color-text-secondary)]">
          <li><a href="#modello" class="hover:text-white transition-colors">Modello</a></li>
          <li><a href="#processo" class="hover:text-white transition-colors">Processo</a></li>
          <li><a href="#valori" class="hover:text-white transition-colors">Valori</a></li>
          <li><a href="#contatto" class="hover:text-white transition-colors">Contatti</a></li>
        </ul>
      </nav>

      <div class="space-y-3">
        <h3 class="text-sm uppercase tracking-[0.2em] text-[var(--color-text-muted)] mb-4">Contatti</h3>
        <ul class="space-y-2 text-[var(--color-text-secondary)] text-sm">
          <li><a href="mailto:tailorappstudio@gmail.com" class="hover:text-white transition-colors">tailorappstudio@gmail.com</a></li>
          <li class="pt-2 text-xs text-[var(--color-text-muted)]">Sassari · Sardegna · Italia</li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col items-center gap-3 py-8 mb-4 border-t border-[var(--color-divider)]">
      <p class="text-sm uppercase tracking-[0.25em] text-[var(--color-text-muted)]">Seguici</p>
      <a
        href="https://instagram.com/tailorappstudio"
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-3 px-7 py-3.5 rounded-full text-white font-semibold transition-all hover:scale-[1.04] hover:shadow-[0_12px_40px_-8px_rgba(221,42,123,0.7)] shadow-[0_8px_30px_-8px_rgba(221,42,123,0.45)]"
        style="background: linear-gradient(135deg, #F58529 0%, #DD2A7B 50%, #8134AF 100%);"
        aria-label="Segui Tailor App Studio su Instagram"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2.5" y="2.5" width="19" height="19" rx="5.5" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="17.6" cy="6.4" r="1.25" fill="currentColor"/>
        </svg>
        <span class="tracking-wide">@tailorappstudio</span>
        <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>

    <div class="border-t border-[var(--color-divider)] pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs text-[var(--color-text-muted)]">
      <div class="space-y-1">
        <p>Angelo Casula · P.IVA 03034130900 · Sassari, Italia</p>
        <p>© {year} Tailor App Studio. Tutti i diritti riservati.</p>
      </div>
      <ul class="flex flex-wrap gap-x-6 gap-y-2">
        <li><a href="/privacy" class="hover:text-white transition-colors">Privacy</a></li>
        <li><a href="/termini" class="hover:text-white transition-colors">Termini e condizioni</a></li>
        <li><a href="/cookie" class="hover:text-white transition-colors">Cookie</a></li>
        <li>
          <button
            type="button"
            data-cookie-manage
            class="hover:text-white transition-colors cursor-pointer"
          >
            Gestisci cookie
          </button>
        </li>
      </ul>
    </div>
  </div>
</footer>

<script is:inline>
  document.querySelectorAll("[data-cookie-manage]").forEach(function (el) {
    el.addEventListener("click", function () {
      if (window.tailorCookieConsent) window.tailorCookieConsent.open();
    });
  });
</script>
