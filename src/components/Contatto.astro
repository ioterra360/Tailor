---
// FormSubmit: invio reale via POST a https://formsubmit.co/<email>
// Prima submit dopo il deploy → FormSubmit invia email di conferma a TARGET_EMAIL.
// Cliccare il link "Activate Form" nell'email per attivare l'endpoint definitivamente.
const TARGET_EMAIL = "tailorappstudio@gmail.com";
const FORM_ACTION = `https://formsubmit.co/${TARGET_EMAIL}`;
const NEXT_URL = "https://tailorappstudio.it/grazie";
---

<section id="contatto" class="section-tailor relative bg-[var(--color-bg-secondary)]">
  <div class="container-tailor max-w-3xl">
    <div class="text-center mb-12 md:mb-16">
      <p class="text-sm uppercase tracking-[0.25em] text-[var(--color-accent-bright)] mb-4">Iniziamo</p>
      <h2 data-reveal class="display-lg text-balance">
        Vuoi ottimizzare il tuo business?
      </h2>
      <p data-reveal class="mt-6 text-lg md:text-xl text-[var(--color-text-secondary)] leading-relaxed max-w-[48ch] mx-auto">
        Scrivici. Risposta entro 24 ore lavorative.
        <span class="block mt-1 text-base text-[var(--color-text-muted)]">Discovery call gratuita di 30 minuti, senza impegno.</span>
      </p>
    </div>

    <form
      data-reveal
      action={FORM_ACTION}
      method="POST"
      class="space-y-5"
      aria-label="Modulo contatto Tailor App Studio"
    >
      <!-- FormSubmit config -->
      <input type="hidden" name="_subject" value="Nuova richiesta — Tailor App Studio" />
      <input type="hidden" name="_next" value={NEXT_URL} />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_autoresponse" value="Ciao, abbiamo ricevuto la tua richiesta. Ti ricontattiamo entro 24 ore lavorative via email o telefono. — Tailor App Studio" />

      <!-- Honeypot anti-bot (FormSubmit standard) -->
      <input
        type="text"
        name="_honey"
        tabindex="-1"
        autocomplete="off"
        class="absolute left-[-9999px]"
        aria-hidden="true"
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-sm font-medium mb-2">
            Nome e cognome <span class="text-[var(--color-accent-bright)]">*</span>
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full rounded-xl bg-[var(--color-bg-tertiary)] border border-[var(--color-divider)] px-4 py-3 text-base text-white placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition"
            placeholder="Mario Rossi"
          />
        </div>
        <div>
          <label for="company" class="block text-sm font-medium mb-2">
            Azienda
          </label>
          <input
            id="company"
            name="company"
            type="text"
            autocomplete="organization"
            class="w-full rounded-xl bg-[var(--color-bg-tertiary)] border border-[var(--color-divider)] px-4 py-3 text-base text-white placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition"
            placeholder="Nome azienda"
          />
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label for="email" class="block text-sm font-medium mb-2">
            Email <span class="text-[var(--color-accent-bright)]">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-xl bg-[var(--color-bg-tertiary)] border border-[var(--color-divider)] px-4 py-3 text-base text-white placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition"
            placeholder="mario@azienda.it"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium mb-2">
            Telefono <span class="text-[var(--color-accent-bright)]">*</span>
          </label>
          <input
            id="phone"
            name="phone"
            type="tel"
            required
            autocomplete="tel"
            inputmode="tel"
            pattern="[+0-9\s().\-]{6,20}"
            class="w-full rounded-xl bg-[var(--color-bg-tertiary)] border border-[var(--color-divider)] px-4 py-3 text-base text-white placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition"
            placeholder="+39 333 1234567"
          />
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium mb-2">
          Cosa vorresti automatizzare o digitalizzare? <span class="text-[var(--color-accent-bright)]">*</span>
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          minlength="20"
          maxlength="2000"
          class="w-full rounded-xl bg-[var(--color-bg-tertiary)] border border-[var(--color-divider)] px-4 py-3 text-base text-white placeholder:text-[var(--color-text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition resize-none"
          placeholder="Es. Gestiamo preventivi e ordini a mano tra Excel e WhatsApp: vorrei un gestionale unico, condiviso col team."
        ></textarea>
      </div>

      <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
        Inviando il modulo accetti la nostra <a href="/privacy" class="underline hover:text-white transition-colors">Privacy Policy</a>.
        I tuoi dati saranno usati solo per ricontattarti via email o telefono.
      </p>

      <button
        type="submit"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-white text-[var(--color-bg-primary)] font-semibold text-base hover:bg-[var(--color-text-secondary)] hover:scale-[1.01] transition-all"
      >
        Invia messaggio
        <span aria-hidden="true">→</span>
      </button>
    </form>
  </div>
</section>
