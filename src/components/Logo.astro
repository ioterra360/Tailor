---
interface Props {
  size?: number;
  className?: string;
  decorative?: boolean;
}

const { size = 64, className = "", decorative = false } = Astro.props;
const alt = decorative ? "" : "Tailor App Studio logo";
---

<img
  src="/logo-tailor.png"
  alt={alt}
  width={size}
  height={size}
  loading="eager"
  decoding="async"
  class={`block object-contain ${className}`}
  style={`width:${size}px;height:${size}px;`}
  data-tailor-logo
/>
