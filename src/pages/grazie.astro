---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Grazie · Tailor App Studio"
  description="Messaggio ricevuto. Ti rispondiamo entro 24 ore lavorative."
>
  <Header />
  <main id="main" class="pt-32 pb-16">
    <div class="container-tailor max-w-2xl text-center min-h-[60vh] flex flex-col justify-center">
      <p class="text-sm uppercase tracking-[0.25em] text-[var(--color-accent-bright)] mb-4">Messaggio inviato</p>
      <h1 class="display-xl mb-8">Grazie.</h1>
      <p class="text-lg md:text-xl text-[var(--color-text-secondary)] leading-relaxed">
        Abbiamo ricevuto il tuo messaggio.
        <span class="block mt-3">Ti rispondiamo entro 24 ore lavorative dall'indirizzo tailorappstudio@gmail.com.</span>
      </p>
      <div class="mt-12">
        <a
          href="/"
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-white text-[var(--color-bg-primary)] font-semibold hover:bg-[var(--color-text-secondary)] transition-colors"
        >
          ← Torna alla home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Base>
