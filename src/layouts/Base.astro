---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Tailor App Studio · Applicazioni cucite su misura per il tuo business",
  description = "Software house premium con sede in Sardegna. Costruiamo app e software su misura per PMI italiane, con modello ad abbonamento mensile e tutto incluso.",
  ogImage = "/og.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Sora font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="it_IT" />
    <meta property="og:site_name" content="Tailor App Studio" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Theme color -->
    <meta name="theme-color" content="#0A2540" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Tailor App Studio",
      "url": "https://tailorappstudio.it",
      "logo": "https://tailorappstudio.it/og.png",
      "description": description,
      "founder": { "@type": "Person", "name": "Angelo Casula" },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Sassari",
        "addressRegion": "SS",
        "addressCountry": "IT"
      },
      "email": "tailorappstudio@gmail.com",
      "vatID": "IT03034130900"
    })} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-[var(--color-bg-primary)] focus:rounded">
      Vai al contenuto
    </a>

    <slot />

    <!-- Lenis smooth scroll + GSAP animations -->
    <script>
      import { initApp } from "../scripts/app";
      initApp();
    </script>
  </body>
</html>
